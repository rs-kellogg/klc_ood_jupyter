# Batch Connect app configuration file
#
# @note Used to define the submitted cluster, title, description, and
form:
  - cluster
  - bc_num_hours
  # Different containers have different kernels installed
  - default_kernel
  # This allows a user to decide if they want to run jupyter lab or jupyter notebook
  - jupyterlab_switch
  # What folder do you want to server as the notebook "root" directory
  - notebook_directory_root
  # Quest Slurm fields (hidden when a KLC node is selected)
  - slurm_partition
  - gres_value
  - slurm_account
  - num_cores
  - memory_per_node
  - user_email
  - job_name
  # Hidden fields used by JavaScript to build partition/account dropdowns
  - raw_data
  - raw_group_data

attributes:
  cluster:
    label: "Cluster"
    widget: select
    options:
      - ["KLC Node 0202", "klc0202"]
      - ["KLC Node 0203", "klc0203"]
      - ["KLC Node 0301", "klc0301"]
      - ["KLC Node 0302", "klc0302"]
      - ["KLC Node 0303", "klc0303"]
      - ["KLC Node 0304", "klc0304"]
      - ["KLC Node 0305", "klc0305"]
      - ["KLC Node 0306", "klc0306"]
      - ["KLC Node 0307", "klc0307"]
      - ["KLC Node 0401", "klc0401"]
      - ["KLC Node 0402", "klc0402"]
      - ["Kellogg Compute Nodes (Slurm)", "quests"]
    value: "klc0202"
    help: |
      Select a KLC node to run directly on Kellogg Computing Center hardware, or
      select Kellogg Compute Nodes (Slurm) to submit a Slurm job on Quest (additional
      fields will appear).

  default_kernel:
    label: "Pre-Installed Kernel"
    help: |
        The Quest OnDemand Jupyter instances come with a pre-installed kernel/virtual environment. You can use the drop down below to determine which pre-installed kernel you would like to have available for your Jupyter session (in addition to all of you user installed kernels). We recommend leaving this as the default value of `ml-data-science-kernel-py311`.
    widget: select
    display: true
    options:
      - [ "ml-data-science-kernel-py311", "/software/rhel8/quest_ondemand/quest_ood_jupyter/rhel8-jupyter-new-ml-data-science.sif" ]

  jupyterlab_switch:
    widget: "check_box"
    label: "Use JupyterLab instead of Jupyter Notebook?"
    help: |
      JupyterLab is the next generation of Jupyter, and is completely compatible with existing Jupyter Notebooks.

  notebook_directory_root:
    label: "Jupyter root directory (Optional)"
    value: ""
    help: |
      If you leave this blank, Jupyter will run from your HOME folder. Otherwise, specify a full PATH to a folder on Quest. This is important to consider if running Jupyter Notebook as it limits the folders and files that Jupyter can see.

  bc_num_hours:
    label: "Wall Clock Time"
    help: |
      The maximum number of hours the session will run for. You can always terminate
      your session early, but it will automatically be terminated once the walltime is hit.
    value: 1

  project_directory:
    label: "Which folder would you like to launch the Copilot CLI from"
    help: |
      Which folder would you like to launch the Copilot CLI from.

  slurm_partition:
    label: "SLURM Partition"
    help: |
      The SLURM partition you want to submit to. This selection will influence which
      accounts you can choose as some partitions can only be submitted to through
      certain accounts.
    value: kellogg

  slurm_account:
    label: "SLURM Account/Project Name"
    help: |
      The SLURM account (i.e., the value of the -A or --account flag used when
      submitting a SLURM job).
    value: kellogg

  gres_value:
    label: "Type of GPU that you would like to request"
    help: |
      If you are submitting to `gengpu` the only option that you can select is `A100`.
    widget: select
    default: ""

  num_cores:
    widget: "number_field"
    label: "Number of CPUs/cores/processors"
    value: 1
    help: |
      Please note that you likely do not need to request more than a single CPU unless
      you know that your application can be parallelized and also please note that the
      more cores requested, the longer the wait for the session to start.
    min: 1
    max: 128
    step: 1
    id: "num_cores"

  memory_per_node:
    widget: "number_field"
    label: "Total memory or RAM do you need in GB."
    value: 5
    help: |
      How much total memory/RAM do you need in GB.
    min: 1
    max: 243
    step: 1
    id: "memory_per_node"

  user_email:
    label: "Email Address (Optional)"
    help: |
      Enter your email address if you would like to receive an email when the session
      starts. Leave blank for no email.

  job_name:
    label: "Job Name"
    value: "vscode-copilot"
    help: |
      The name of the Slurm job as it will appear in the queue.

  raw_data:
    label: "Account associations for use by JavaScript"
    widget: hidden_field
    value: "<%= RawSlurmData.read_sinfo_from_file %>"
    cacheable: false

  raw_group_data:
    label: "linux groups for use by JavaScript"
    widget: hidden_field
    value: "<%= RawSlurmData.rawgroupdata %>"
    cacheable: false
